{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TODOCompanion",
  "version": "0.1.1",
  "identifier": "com.rafael.todocompanion",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "TODOCompanion",
        "width": 34,
        "height": 64,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "shadow": false,
        "visible": true,
        "skipTaskbar": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": [],
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
